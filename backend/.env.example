# ZIMON API — copy to `backend/.env` or use repo root `.env` (gitignored).
# Loaded automatically when `python-dotenv` is installed (comes with pydantic-settings).

# --- Server bind (local defaults: 127.0.0.1:8010) ---
# ZIMON_API_HOST=127.0.0.1
# ZIMON_API_PORT=8010

# --- Security ---
# ZIMON_JWT_SECRET=use-a-long-random-string-here

# --- CORS: comma-separated browser origins (Vite dev + Electron packaged UI on 5180) ---
# ZIMON_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://127.0.0.1:5180

# --- Optional admin recovery (leave empty if unused) ---
# ZIMON_RECOVERY_SECRET=dscxvfbfrertdrer46534ewdsdwe3e454fef
# ZIMON_RECOVERY_ALLOW_IPS=

# --- Stack toggles ---
# ZIMON_DISABLE_QT=1
# ZIMON_DEV=1

# --- Paths ---
# ZIMON_DATABASE_PATH=
# ZIMON_RECORDINGS_ROOT=
