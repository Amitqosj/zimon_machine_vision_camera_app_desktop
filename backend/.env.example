# ZIMON API — copy to `backend/.env` or use repo root `.env` (gitignored).
# Loaded automatically when `python-dotenv` is installed (comes with pydantic-settings).

# --- Server bind (local dev defaults: 127.0.0.1:8010) ---
# ZIMON_API_HOST=127.0.0.1
# ZIMON_API_PORT=8010
# PORT is set by Render/Railway/Heroku; do not set locally unless you know why.

# --- Security (required in production) ---
# ZIMON_JWT_SECRET=use-a-long-random-string-here

# --- CORS: comma-separated browser origins (your Vite dev server or deployed frontend URL) ---
# ZIMON_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Optional admin recovery (leave empty if unused) ---
# ZIMON_RECOVERY_SECRET=
# ZIMON_RECOVERY_ALLOW_IPS=

# --- Stack toggles ---
# ZIMON_DISABLE_QT=1
# ZIMON_DEV=1

# --- Paths ---
# ZIMON_DATABASE_PATH=
# ZIMON_RECORDINGS_ROOT=
