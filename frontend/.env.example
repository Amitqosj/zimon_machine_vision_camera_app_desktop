# Base URL of the FastAPI service (no trailing slash). Build-time for Vite.
VITE_API_URL=http://127.0.0.1:8010

# Desktop (Electron): UI is served at http://127.0.0.1:5180 in production builds; ensure the API
# allows that origin (see backend ZIMON_CORS_ORIGINS). To start only the window without spawning Python:
# ZIMON_SKIP_API_SPAWN=1
